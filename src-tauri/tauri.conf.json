{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ML-Maid",
  "version": "0.5.1",
  "identifier": "dev.kurosu.ml-maid",
  "build": {
    "beforeDevCommand": "npm run dev:front",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:front",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ML-Maid",
        "width": 1300,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
